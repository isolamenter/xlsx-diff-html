{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "xlsx-diff-html",
  "version": "0.1.0",
  "identifier": "com.isolameto.xlsx-diff-html",
  "build": {},
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/server"],
    "resources": {
      "../../xlsx-diff-html-web/app/public/**/*": "public/"
    }
  }
}
