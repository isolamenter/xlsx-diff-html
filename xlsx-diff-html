#!/usr/bin/env bash
set -euo pipefail

XLSX2CSV="${XLSX2CSV:-}"
if [[ -z "$XLSX2CSV" ]]; then
  XLSX2CSV="$(command -v xlsx2csv || true)"
fi

usage() {
  cat <<'EOF'
Usage:
  xlsx-diff-html [options] FILE.xlsx [FILE2.xlsx ...]
  xlsx-diff-html [options] --changed

Options:
  --all                     Export every sheet; sheets are separated by a blank line.
  --sheet N                 Export sheet N (1-based). Default: 1.
  --staged                  Compare HEAD vs staged index instead of working tree.
  --changed                 Compare all changed .xlsx files reported by git status.
  --ignore-empty            Drop blank rows from the exported CSV.
  --skip-hidden             Skip rows and columns hidden in the sheet. Default: keep them.
  --raw                     Emit raw cell values instead of Excel-formatted display text.
  --date-format FORMAT      Render date cells with an Excel number-format code,
                            for example "yyyy-mm-dd". Default: yyyy-mm-dd.
                            Pass an empty string (--date-format "") to keep each
                            cell's own displayed date format instead.
  --open                    Open generated HTML in the browser. Default.
  --no-open                 Do not open generated HTML.
  --output PATH             Output HTML file for one input, or output directory for many.
  -h, --help                Show this help.
EOF
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

warn() {
  printf 'Warning: %s\n' "$*" >&2
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1"
}

is_xlsx_path() {
  local lower
  lower=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
  [[ "$lower" == *.xlsx ]]
}

safe_html_name() {
  printf '%s' "$1" | tr '/[:space:]' '___' | sed 's/[^A-Za-z0-9._-]/_/g'
}

display_path() {
  local path="$1"
  case "$path" in
    "$repo_root"/*) printf '%s\n' "${path#"$repo_root"/}" ;;
    *) printf '%s\n' "$path" ;;
  esac
}

absolute_from_invocation_dir() {
  local path="$1"
  case "$path" in
    /*) printf '%s\n' "$path" ;;
    *) printf '%s\n' "$invocation_pwd/$path" ;;
  esac
}

add_file_once() {
  local candidate="$1"
  local existing
  if [[ "$files_count" -gt 0 ]]; then
    for existing in "${files[@]}"; do
      [[ "$existing" == "$candidate" ]] && return 0
    done
  fi
  files+=("$candidate")
  files_count=$((files_count + 1))
}

normalize_file_path() {
  local input="$1"
  local rel=""
  local prefix=""

  rel=$(git -C "$invocation_pwd" ls-files --full-name -- "$input" 2>/dev/null | sed -n '1p')
  if [[ -z "$rel" ]]; then
    rel=$(git -C "$invocation_pwd" ls-files --others --exclude-standard --full-name -- "$input" 2>/dev/null | sed -n '1p')
  fi

  if [[ -z "$rel" ]]; then
    if [[ "$input" == /* ]]; then
      case "$input" in
        "$repo_root"/*) rel="${input#"$repo_root"/}" ;;
        *) die "file is outside Git repo: $input" ;;
      esac
    else
      prefix=$(git -C "$invocation_pwd" rev-parse --show-prefix 2>/dev/null || true)
      rel="${prefix}${input}"
    fi
  fi

  rel="${rel#./}"
  [[ -n "$rel" ]] || die "empty file path: $input"
  printf '%s\n' "$rel"
}

collect_changed_xlsx_files() {
  local entry=""
  local status=""
  local path=""
  local old_path=""

  while IFS= read -r -d '' entry; do
    status="${entry:0:2}"
    path="${entry:3}"

    case "$status" in
      R*|C*)
        IFS= read -r -d '' old_path || true
        ;;
    esac

    if is_xlsx_path "$path"; then
      add_file_once "$path"
    fi
  done < <(git status --porcelain=v1 -z --untracked-files=all -- '*.xlsx')
}

write_head_xlsx() {
  local file="$1"
  local output="$2"

  if git show "HEAD:$file" >"$output" 2>/dev/null; then
    printf '1\n'
  else
    : >"$output"
    printf '0\n'
  fi
}

write_index_xlsx() {
  local file="$1"
  local output="$2"

  if git show ":$file" >"$output" 2>/dev/null; then
    printf '1\n'
  else
    : >"$output"
    printf '0\n'
  fi
}

write_working_xlsx() {
  local file="$1"
  local output="$2"

  if [[ -f "$file" ]]; then
    cp "$file" "$output"
    printf '1\n'
  else
    : >"$output"
    printf '0\n'
  fi
}

convert_xlsx_to_csv() {
  local present="$1"
  local xlsx="$2"
  local csv="$3"
  local label="$4"
  local args=()

  if [[ "$present" != "1" ]]; then
    : >"$csv"
    return 0
  fi

  if [[ "$skip_hidden" != "1" ]]; then
    args+=("--include-hidden-rows")
  fi

  if [[ "$all_sheets" == "1" ]]; then
    args+=("-a" "-p" "")
  else
    args+=("-s" "$sheet")
  fi

  if [[ "$ignore_empty" == "1" ]]; then
    args+=("-i")
  fi

  if [[ "$raw" == "1" ]]; then
    args+=("--raw")
  fi

  if [[ -n "$date_format" ]]; then
    args+=("-f" "$date_format")
  fi

  if ! "$XLSX2CSV" "${args[@]}" "$xlsx" >"$csv"; then
    die "xlsx2csv failed for $label"
  fi
}

output_path_for_file() {
  local file="$1"
  local safe_name="$2"
  local output_abs=""

  if [[ -n "$output_path" ]]; then
    output_abs=$(absolute_from_invocation_dir "$output_path")
    if [[ "$file_count" -eq 1 && "$output_path" != */ && ! -d "$output_abs" ]]; then
      printf '%s\n' "$output_abs"
    else
      printf '%s/%s.diff.html\n' "${output_abs%/}" "$safe_name"
    fi
  else
    printf '%s/%s.diff.html\n' "$default_output_dir" "$safe_name"
  fi
}

run_one_diff() {
  local input="$1"
  local file=""
  local safe_name=""
  local html=""
  local old_xlsx=""
  local new_xlsx=""
  local old_csv=""
  local new_csv=""
  local old_present=""
  local new_present=""
  local daff_status=0
  local daff_log=""
  local no_diff=0

  file=$(normalize_file_path "$input")
  is_xlsx_path "$file" || die "not an .xlsx file: $input"

  safe_name=$(safe_html_name "$file")
  html=$(output_path_for_file "$file" "$safe_name")
  mkdir -p "${html%/*}"

  diff_index=$((diff_index + 1))
  old_xlsx="$tmp_dir/$diff_index.old.xlsx"
  new_xlsx="$tmp_dir/$diff_index.new.xlsx"
  old_csv="$tmp_dir/$diff_index.old.csv"
  new_csv="$tmp_dir/$diff_index.new.csv"

  old_present=$(write_head_xlsx "$file" "$old_xlsx")
  if [[ "$staged" == "1" ]]; then
    new_present=$(write_index_xlsx "$file" "$new_xlsx")
  else
    new_present=$(write_working_xlsx "$file" "$new_xlsx")
  fi

  convert_xlsx_to_csv "$old_present" "$old_xlsx" "$old_csv" "HEAD:$file"
  if [[ "$staged" == "1" ]]; then
    convert_xlsx_to_csv "$new_present" "$new_xlsx" "$new_csv" "index:$file"
  else
    convert_xlsx_to_csv "$new_present" "$new_xlsx" "$new_csv" "working tree:$file"
  fi

  if cmp -s "$old_csv" "$new_csv"; then
    no_diff=1
  fi

  daff_log="$tmp_dir/$diff_index.daff.stderr"
  set +e
  daff --output "$html" "$old_csv" "$new_csv" 2>"$daff_log"
  daff_status=$?
  set -e

  if [[ "$daff_status" -ne 0 && ! -s "$html" ]]; then
    if [[ -s "$daff_log" ]]; then
      cat "$daff_log" >&2
    fi
    die "daff failed for $file with exit code $daff_status"
  elif [[ "$daff_status" -ne 0 ]]; then
    warn "daff returned exit code $daff_status for $file, but HTML was generated"
  fi

  printf 'Comparing: %s\n' "$file"
  if [[ "$staged" == "1" ]]; then
    printf 'Mode: HEAD vs staged index\n'
  else
    printf 'Mode: HEAD vs working tree\n'
  fi
  if [[ "$all_sheets" == "1" ]]; then
    printf 'Sheet: all\n'
  else
    printf 'Sheet: %s\n' "$sheet"
  fi
  printf 'HTML: %s\n' "$(display_path "$html")"
  if [[ "$no_diff" == "1" ]]; then
    printf 'Diff: no table diff\n'
  fi

  if [[ "$auto_open" == "1" ]]; then
    if command -v open >/dev/null 2>&1; then
      if ! open "$html" >/dev/null 2>&1; then
        warn "failed to open browser for $(display_path "$html")"
      fi
    else
      warn "open not found; generated HTML was not opened"
    fi
  fi
}

all_sheets=0
sheet="1"
staged=0
changed=0
ignore_empty=0
skip_hidden=0
raw=0
date_format="yyyy-mm-dd"
auto_open=1
output_path=""
files=()
files_count=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --all)
      all_sheets=1
      shift
      ;;
    --sheet)
      [[ $# -ge 2 ]] || die "--sheet requires a sheet number"
      sheet="$2"
      [[ "$sheet" =~ ^[0-9]+$ && "$sheet" -ge 1 ]] || die "--sheet must be a positive integer"
      all_sheets=0
      shift 2
      ;;
    --staged)
      staged=1
      shift
      ;;
    --changed)
      changed=1
      shift
      ;;
    --ignore-empty)
      ignore_empty=1
      shift
      ;;
    --skip-hidden)
      skip_hidden=1
      shift
      ;;
    --raw)
      raw=1
      shift
      ;;
    --date-format)
      [[ $# -ge 2 ]] || die "--date-format requires a format string"
      date_format="$2"
      shift 2
      ;;
    --open)
      auto_open=1
      shift
      ;;
    --no-open)
      auto_open=0
      shift
      ;;
    --output)
      [[ $# -ge 2 ]] || die "--output requires a path"
      output_path="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        add_file_once "$1"
        shift
      done
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      add_file_once "$1"
      shift
      ;;
  esac
done

need_cmd git
need_cmd daff
[[ -n "$XLSX2CSV" && -x "$XLSX2CSV" ]] || die "missing executable dependency: xlsx2csv; set XLSX2CSV or add xlsx2csv to PATH"

invocation_pwd=$(pwd)
repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || die "not a Git repository"
cd "$repo_root"
git_dir=$(git rev-parse --git-dir)
default_output_dir="$git_dir/xlsx-diff-html"

tmp_dir=$(mktemp -d "${TMPDIR:-/tmp}/xlsx-diff-html.XXXXXX")
trap 'rm -rf "$tmp_dir"' EXIT

if [[ "$changed" == "1" ]]; then
  collect_changed_xlsx_files
fi

if [[ "$files_count" -eq 0 ]]; then
  if [[ "$changed" == "1" ]]; then
    die "no changed .xlsx files found"
  fi
  usage >&2
  exit 1
fi

file_count="$files_count"
if [[ -n "$output_path" && "$file_count" -gt 1 ]]; then
  output_abs=$(absolute_from_invocation_dir "$output_path")
  if [[ "$output_path" != */ && ! -d "$output_abs" ]]; then
    die "--output must be a directory when comparing multiple files"
  fi
fi

if [[ "$changed" == "1" ]]; then
  printf 'Changed .xlsx files:\n'
  for file in "${files[@]}"; do
    printf '  %s\n' "$file"
  done
  printf '\n'
fi

diff_index=0
for file in "${files[@]}"; do
  run_one_diff "$file"
  if [[ "$file_count" -gt 1 ]]; then
    printf '\n'
  fi
done
