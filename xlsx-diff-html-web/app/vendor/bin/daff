#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
APP_DIR="$(cd "$SCRIPT_DIR/../.." >/dev/null 2>&1 && pwd)"
NODE_BIN="$APP_DIR/vendor/node/bin/node"
DAFF_JS="$APP_DIR/vendor/daff/bin/daff.js"

if [[ -x "$NODE_BIN" && -f "$DAFF_JS" ]]; then
  exec "$NODE_BIN" "$DAFF_JS" "$@"
fi

if [[ -n "${XLSX_DIFF_HTML_DEV_DAFF:-}" && -x "$XLSX_DIFF_HTML_DEV_DAFF" ]]; then
  exec "$XLSX_DIFF_HTML_DEV_DAFF" "$@"
fi

echo "Error: bundled daff was not found." >&2
exit 1
