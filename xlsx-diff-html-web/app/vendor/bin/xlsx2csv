#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
APP_DIR="$(cd "$SCRIPT_DIR/../.." >/dev/null 2>&1 && pwd)"
NODE_BIN="$APP_DIR/vendor/node/bin/node"
CONVERTER="$APP_DIR/vendor/xlsx2csv-node.mjs"

if [[ ! -x "$NODE_BIN" ]]; then
  NODE_BIN="$(command -v node || true)"
fi

if [[ -x "$NODE_BIN" && -f "$CONVERTER" ]]; then
  exec "$NODE_BIN" "$CONVERTER" "$@"
fi

if [[ -n "${XLSX_DIFF_HTML_DEV_XLSX2CSV:-}" && -x "$XLSX_DIFF_HTML_DEV_XLSX2CSV" ]]; then
  exec "$XLSX_DIFF_HTML_DEV_XLSX2CSV" "$@"
fi

echo "Error: bundled Node xlsx2csv converter was not found." >&2
exit 1
