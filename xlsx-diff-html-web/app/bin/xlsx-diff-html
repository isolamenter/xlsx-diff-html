#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
APP_DIR="$(cd "$SCRIPT_DIR/.." >/dev/null 2>&1 && pwd)"
PACKAGE_ROOT="$(cd "$APP_DIR/.." >/dev/null 2>&1 && pwd)"

if [[ -x "$SCRIPT_DIR/xlsx-diff-html-engine" ]]; then
  exec "$SCRIPT_DIR/xlsx-diff-html-engine" "$@"
fi

if [[ -x "$PACKAGE_ROOT/../xlsx-diff-html" ]]; then
  exec "$PACKAGE_ROOT/../xlsx-diff-html" "$@"
fi

if [[ -x "$PACKAGE_ROOT/xlsx-diff-html" ]]; then
  exec "$PACKAGE_ROOT/xlsx-diff-html" "$@"
fi

echo "Error: xlsx-diff-html engine was not found." >&2
exit 1
